{
  "name": "@j3os/cli",
  "version": "0.1.0",
  "description": "Command-line interface for J3OS Framework",
  "main": "dist/index.js",
  "bin": {
    "j3os": "./bin/j3os.js"
  },
  "scripts": {
    "build": "mkdir -p bin && touch bin/j3os.js && chmod +x bin/j3os.js",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "files": [
    "dist",
    "bin",
    "j3os.ps1",
    "j3os.sh"
  ],
  "keywords": [
    "j3os",
    "cli",
    "defi",
    "trading",
    "ai",
    "swarm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j3os/framework.git"
  },
  "author": "J3OS",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/j3os/framework/issues"
  },
  "homepage": "https://github.com/j3os/framework#readme",
  "dependencies": {
    "commander": "^8.0.0",
    "chalk": "^4.1.2",
    "inquirer": "^8.0.0",
    "ora": "^5.4.1",
    "fs-extra": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^16.0.0",
    "@types/fs-extra": "^9.0.0",
    "@types/inquirer": "^8.0.0",
    "@types/jest": "^27.0.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.0",
    "jest": "^27.0.0",
    "prettier": "^2.0.0",
    "ts-jest": "^27.0.0",
    "typescript": "^4.0.0"
  }
} 