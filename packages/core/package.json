{
  "name": "@juliaos/core",
  "version": "0.1.0",
  "description": "Core package for JuliaOS - A Web3 Cross-Chain AI Agent Framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm test",
    "clean": "rimraf dist",
    "dev": "tsc -w",
    "start": "node dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "web3",
    "blockchain",
    "ai",
    "julia",
    "defi",
    "cross-chain",
    "swarm",
    "optimization"
  ],
  "author": "JuliaOS Contributors <contributors@juliaos.org>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/juliaos/core.git"
  },
  "bugs": {
    "url": "https://github.com/juliaos/core/issues"
  },
  "homepage": "https://github.com/juliaos/core#readme",
  "dependencies": {
    "ethers": "^6.11.1",
    "ws": "^8.16.0",
    "zod": "^3.22.4",
    "events": "^3.3.0",
    "dotenv": "^16.4.5",
    "winston": "^3.11.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/ws": "^8.5.10",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
} 